{
  "name": "zypher",
  "version": "1.0.0",
  "description": "Local-first Windows journal with rich text editing, backups, exports, and privacy-focused local storage.",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist-electron/electron/main.js && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "build:exe": "node -e \"require('fs').rmSync('release',{recursive:true,force:true})\" && npm run build && electron-packager . Zypher --platform=win32 --arch=x64 --out=release --overwrite --asar --prune=true --icon=assets/icon.ico --ignore=\"^/src($|/)\" --ignore=\"^/electron($|/)\" --ignore=\"^/shared($|/)\" --ignore=\"^/release.*($|/)\" --ignore=\"^/tsconfig\" --ignore=\"^/vite\\.config\\.ts$\" --ignore=\"\\.test\\.ts$\"",
    "build:dir": "npm run build:exe",
    "build:installer": "npm run build:installer:custom",
    "build:installer:inno": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-installer.ps1",
    "build:installer:nsis": "node -e \"require('fs').rmSync('release-installer',{recursive:true,force:true})\" && npm run build && electron-builder --win nsis --x64",
    "build:installer:custom": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-custom-installer.ps1",
    "create:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-shortcut.ps1"
  },
  "keywords": [],
  "author": "Zypher contributors",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/dancing-script": "^5.2.8",
    "@fontsource/merriweather": "^5.2.11",
    "@fontsource/patrick-hand": "^5.2.8",
    "@types/adm-zip": "^0.5.7",
    "adm-zip": "^0.5.16",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.zypher.app",
    "productName": "Zypher",
    "directories": {
      "output": "release-installer",
      "buildResources": "assets"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "assets/**",
      "package.json",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Zypher-Setup-${version}.${ext}",
      "executableName": "Zypher"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zypher",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
